# === .NET Specific (Obrigatório) ===
bin/
obj/
TestResults/
_ReSharper*/
*.user
*.userosscache
*.sln.docstates
.vs/

# === Dependências (Gerenciadores de Pacotes) ===
# NuGet packages (exceto se você usa o estilo antigo de packages.config com pasta local)
packages/
# Node.js (caso tenha front-end)
node_modules/
jspm_packages/

# === Logs e Arquivos de Debug ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# === Arquivos de Ambiente e Segredos (CRÍTICO) ===
.env
.env.*
!.env.example
appsettings.Development.json
appsettings.Local.json
*.secret
*.key
*.pfx
*.publishsettings

# === Builds de Produção e Arquivos Gerados ===
dist/
build/
output/
out/
publish/
coverage/
*.tmp
*.temp

# === IDEs e Editores ===
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sw?
# Removido *.sln daqui, pois a Solution deve ser commitada!

# === Sistema Operacional ===
.DS_Store
Thumbs.db
desktop.ini

# === Dados Pesados (OSRM) ===
osrm-data/*
!osrm-data/.gitkeep

# === Protos Gerados (Opcional, mas recomendado) ===
# O gRPC gera esses arquivos no build, não precisam ir pro Git
**/obj/
**/bin/

# === Database e Prisma ===
# Ignorar arquivos de banco de dados locais se existirem
*.db
*.db-journal
/generated/